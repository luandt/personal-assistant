# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/assistant
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/assistant

# Redis
REDIS_URL=redis://redis:6379/0

# NVIDIA embeddings
NVIDIA_API_KEY=your_nvidia_api_key_here
# If your NVIDIA provider requires a custom endpoint, set it here.
# NVIDIA_API_ENDPOINT=https://api.nvidia.com

# App
APP_ENV=development
SECRET_KEY=change_me_in_production
